<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_du_an_document_form" model="ir.ui.view">
        <field name="name">quan_ly.du_an.document.form</field>
        <field name="model">quan_ly.du_an.document</field>
        <field name="arch" type="xml">
            <form string="Tài liệu">
                <header>
                    <field name="approval_status" widget="statusbar" statusbar_visible="draft,review,approved"/>
                </header>
                <sheet>
                    <div class="mb-4">
                        <field name="document_status_html" widget="html" nolabel="1"/>
                    </div>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="category"/>
                            <field name="version"/>
                            <field name="importance_level"/>
                        </group>
                        <group>
                            <field name="link" widget="url"/>
                            <field name="description"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_du_an_document_tree" model="ir.ui.view">
        <field name="name">quan_ly.du_an.document.tree</field>
        <field name="model">quan_ly.du_an.document</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="category" widget="badge"/>
                <field name="importance_level" widget="badge" decoration-danger="importance_level == 'high'"/>
                <field name="approval_status" widget="badge" decoration-success="approval_status == 'approved'"/>
                <field name="link" widget="url"/>
                <field name="version"/>
            </tree>
        </field>
    </record>
</odoo>
