<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_du_an_issue_form" model="ir.ui.view">
        <field name="name">quan_ly.du_an.issue.form</field>
        <field name="model">quan_ly.du_an.issue</field>
        <field name="arch" type="xml">
            <form string="Chi tiết Vấn đề">
                <header>
                    <field name="status" widget="statusbar" statusbar_visible="new,in_progress,resolved,closed"/>
                </header>
                <sheet>
                    <div class="mb-4">
                        <field name="issue_ticket_html" widget="html" nolabel="1"/>
                    </div>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="priority" widget="priority"/>
                            <field name="severity"/>
                        </group>
                        <group>
                            <field name="blocker_score"/>
                            <field name="is_blocker" widget="boolean_toggle"/>
                            <field name="assignee_id" widget="many2one_avatar"/>
                            <field name="description"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_du_an_issue_tree" model="ir.ui.view">
        <field name="name">quan_ly.du_an.issue.tree</field>
        <field name="model">quan_ly.du_an.issue</field>
        <field name="arch" type="xml">
            <tree decoration-danger="is_blocker == True" decoration-warning="priority == '1'">
                <field name="name"/>
                <field name="priority" widget="priority"/>
                <field name="severity" widget="badge" decoration-danger="severity == 'high'"/>
                <field name="blocker_score" widget="progressbar"/>
                <field name="assignee_id" widget="many2one_avatar"/>
                <field name="status" widget="badge"/>
                <field name="is_blocker" invisible="1"/>
            </tree>
        </field>
    </record>
</odoo>
