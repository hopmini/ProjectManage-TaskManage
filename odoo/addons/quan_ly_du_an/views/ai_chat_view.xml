<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_quan_ly_ai_chat_form" model="ir.ui.view">
            <field name="name">quan_ly.ai_chat.form</field>
            <field name="model">quan_ly.ai_chat</field>
            <field name="arch" type="xml">
                <form string="AI Assistant" create="0" delete="0" duplicate="0">
                    <header>
                        <button name="action_clear_history" string="Xóa lịch sử" type="object" class="btn-secondary"/>
                    </header>
                    <sheet>
                        <div style="background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 8px; padding: 20px; height: 500px; overflow-y: auto; margin-bottom: 20px;">
                            <field name="history_html" widget="html" nolabel="1" readonly="1"/>
                        </div>
                        <div style="display: flex; gap: 10px; align-items: flex-end;">
                            <div style="flex-grow: 1;">
                                <field name="message_input" nolabel="1" placeholder="Nhập câu hỏi của bạn tại đây..." style="width: 100%; border: 1px solid #cbd5e1; border-radius: 5px; padding: 10px; font-size: 14px; min-height: 40px;"/>
                            </div>
                            <button name="action_send_message" string="Gửi" type="object" class="btn-primary" style="height: 40px; min-width: 80px; font-weight: bold;"/>
                        </div>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_quan_ly_ai_chat" model="ir.actions.act_window">
            <field name="name">AI Chat</field>
            <field name="res_model">quan_ly.ai_chat</field>
            <field name="view_mode">form</field>
            <field name="res_id" ref="default_ai_chat_session"/>
            <field name="target">current</field>
        </record>
    </data>
</odoo>
