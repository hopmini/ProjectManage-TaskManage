<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_du_an_resource_form" model="ir.ui.view">
        <field name="name">quan_ly.du_an.resource.form</field>
        <field name="model">quan_ly.du_an.resource</field>
        <field name="arch" type="xml">
            <form string="Chi tiết Tài nguyên">
                <sheet>
                    <div class="mb-4">
                        <field name="resource_capacity_html" widget="html" nolabel="1"/>
                    </div>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="type"/>
                            <field name="workload_percent"/>
                        </group>
                        <group>
                            <field name="quantity"/>
                            <field name="unit_price" widget="monetary"/>
                            <field name="total_cost" widget="monetary"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_du_an_resource_tree" model="ir.ui.view">
        <field name="name">quan_ly.du_an.resource.tree</field>
        <field name="model">quan_ly.du_an.resource</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="type"/>
                <field name="workload_percent" widget="progressbar"/>
                <field name="quantity"/>
                <field name="total_cost" widget="monetary" sum="Tổng cộng"/>
            </tree>
        </field>
    </record>
</odoo>
