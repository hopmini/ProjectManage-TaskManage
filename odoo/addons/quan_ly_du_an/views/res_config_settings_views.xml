<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.quan_ly_du_an</field>
        <field name="model">res.config.settings</field>
        <field name="priority" eval="30"/>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[hasclass('settings')]" position="inside">
                <div class="app_settings_block" data-string="Quản trị Dự án Odoo" string="Quản trị Dự án Odoo" data-key="quan_ly_du_an">
                    <h2>Cấu hình Dự án &amp; AI</h2>
                    <div class="row mt16 o_settings_container" id="quan_ly_ai_setting">
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane"/>
                            <div class="o_setting_right_pane">
                                <label for="quan_ly_groq_api_key" string="Groq API Key (Llama 3)"/>
                                <div class="text-muted">
                                    Cung cấp khả năng phân tích biểu đồ Heatmap và Auto-Planner tự động.
                                </div>
                                <div class="mt8">
                                    <field name="quan_ly_groq_api_key" password="True"/>
                                </div>
                            </div>
                        </div>
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane"/>
                            <div class="o_setting_right_pane">
                                <label for="quan_ly_telegram_bot_token" string="Telegram Bot Token"/>
                                <div class="text-muted">
                                    Cung cấp token để Trung tâm gửi thông báo khẩn cấp real-time.
                                </div>
                                <div class="mt8">
                                    <field name="quan_ly_telegram_bot_token" password="True"/>
                                </div>
                                <label for="quan_ly_telegram_chat_id" string="Default Chat ID" class="mt16"/>
                                <div class="text-muted">
                                    Chat ID mặc định (Cá nhân hoặc Group) để nhận báo cáo tự động.
                                </div>
                                <div class="mt8">
                                    <field name="quan_ly_telegram_chat_id"/>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>

    <record id="quan_ly_config_settings_action" model="ir.actions.act_window">
        <field name="name">Thiết lập Quản trị Dự án</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">res.config.settings</field>
        <field name="view_mode">form</field>
        <field name="target">inline</field>
        <field name="context">{'module' : 'quan_ly_du_an'}</field>
    </record>

    <menuitem id="menu_quan_ly_du_an_settings"
              name="Cấu hình Hệ thống"
              parent="menu_quan_ly_du_an_root"
              sequence="100"
              action="quan_ly_config_settings_action"/>
</odoo>
