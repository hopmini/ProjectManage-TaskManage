<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_du_an_stakeholder_form" model="ir.ui.view">
        <field name="name">quan_ly.du_an.stakeholder.form</field>
        <field name="model">quan_ly.du_an.stakeholder</field>
        <field name="arch" type="xml">
            <form string="Bên liên quan">
                <sheet>
                    <div class="mb-4">
                        <field name="stakeholder_card_html" widget="html" nolabel="1"/>
                    </div>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="organization"/>
                            <field name="role"/>
                            <field name="influence_score" widget="percentpie"/>
                        </group>
                        <group>
                            <field name="email" widget="email"/>
                            <field name="phone" widget="phone"/>
                            <field name="note"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_du_an_stakeholder_tree" model="ir.ui.view">
        <field name="name">quan_ly.du_an.stakeholder.tree</field>
        <field name="model">quan_ly.du_an.stakeholder</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="role"/>
                <field name="organization"/>
                <field name="influence_score" widget="progressbar"/>
                <field name="email" widget="email"/>
                <field name="phone" widget="phone"/>
            </tree>
        </field>
    </record>
</odoo>
