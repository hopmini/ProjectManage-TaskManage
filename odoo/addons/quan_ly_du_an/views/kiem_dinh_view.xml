<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_du_an_quality_form" model="ir.ui.view">
        <field name="name">quan_ly.du_an.quality.form</field>
        <field name="model">quan_ly.du_an.quality</field>
        <field name="arch" type="xml">
            <form string="Thông tin Kiểm định">
                <sheet>
                    <div class="mb-4">
                        <field name="quality_gauge_html" widget="html" nolabel="1"/>
                    </div>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="quality_score"/>
                            <field name="is_passed" widget="boolean_toggle"/>
                            <field name="risk_factor"/>
                        </group>
                        <group>
                            <field name="inspector_id" widget="many2one_avatar"/>
                            <field name="check_date"/>
                            <field name="result_note"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_du_an_quality_tree" model="ir.ui.view">
        <field name="name">quan_ly.du_an.quality.tree</field>
        <field name="model">quan_ly.du_an.quality</field>
        <field name="arch" type="xml">
            <tree decoration-success="is_passed == True" decoration-danger="is_passed == False">
                <field name="name"/>
                <field name="quality_score" widget="progressbar"/>
                <field name="is_passed" widget="boolean_toggle"/>
                <field name="inspector_id" widget="many2one_avatar"/>
                <field name="check_date"/>
            </tree>
        </field>
    </record>
</odoo>
