<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- 1. DASHBOARD VIEW -->
        <record id="view_quan_ly_dashboard_form" model="ir.ui.view">
            <field name="name">quan_ly.dashboard.form</field>
            <field name="model">quan_ly.dashboard</field>
            <field name="arch" type="xml">
                <form string="Bảng điều hành" edit="0" create="0" delete="0">
                    <style>
                        .o_form_view .o_form_sheet_bg > .o_form_sheet {
                            max-width: 100% !important;
                            width: 100% !important;
                            padding: 0 !important;
                            margin: 0 !important;
                            border: none !important;
                        }
                    </style>
                    <header>
                        <button name="action_generate_ai_report" type="object" string="AI BÁO CÁO TỔNG HỢP" class="btn btn-primary oe_highlight" icon="fa-magic"/>
                        <button name="%(action_quan_ly_du_an)d" type="action" string="TẠO DỰ ÁN" class="btn btn-success" icon="fa-plus-circle"/>
                        <button name="%(action_quan_ly_du_an_line)d" type="action" string="GIAO VIỆC NHANH" class="btn btn-info" icon="fa-tasks"/>
                    </header>
                    <sheet>
                        <div class="o_executive_dashboard">
                            <field name="dashboard_html" widget="html" nolabel="1"/>
                            <field name="ai_report_html" widget="html" nolabel="1" attrs="{'invisible': [('ai_report_html', '=', False)]}"/>
                        </div>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- 2. ACTION -->
        <record id="action_quan_ly_dashboard_global" model="ir.actions.server">
            <field name="name">Bảng điều hành</field>
            <field name="model_id" ref="model_quan_ly_dashboard"/>
            <field name="state">code</field>
            <field name="code">
                action = model.open_dashboard()
            </field>
        </record>

        <!-- 3. MENU -->
    </data>
</odoo>
