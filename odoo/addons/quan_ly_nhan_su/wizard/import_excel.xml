<odoo>
    <record id="view_import_nhan_vien_form" model="ir.ui.view">
        <field name="name">import.nhan.vien.form</field>
        <field name="model">quan_ly.import.nhan.vien</field>
        <field name="arch" type="xml">
            <form string="Import Nhân Viên">
                <group>
                    <field name="file_excel" filename="file_name"/>
                    <field name="file_name" invisible="1"/>
                </group>
                <footer>
                    <button name="action_import" string="Nhập dữ liệu" type="object" class="btn-primary"/>
                    <button string="Hủy" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_import_nhan_vien" model="ir.actions.act_window">
        <field name="name">Import Nhân Viên Excel</field>
        <field name="res_model">quan_ly.import.nhan.vien</field>
        <field name="view_mode">form</field>
        <field name="target">new</field> </record>

    <menuitem id="menu_import_nhan_vien" 
              name="Import Excel" 
              parent="menu_ho_so" 
              action="action_import_nhan_vien" 
              sequence="3"/>
</odoo>